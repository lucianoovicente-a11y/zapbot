# =====================================================
# CONFIGURAÇÕES DO ZAPPBOT
# =====================================================

# =====================================================
# Google OAuth (Opcional)
# =====================================================
# Se você não quer usar login com Google, deixe vazio
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=/auth/google/callback

# =====================================================
# Segurança
# =====================================================
# Session Secret - Gere uma chave forte e única
SESSION_SECRET=coloque-uma-chave-secreta-forte-aqui-mude-isso

# =====================================================
# URL Pública
# =====================================================
# Seu domínio ou IP público (sem http://)
# Exemplo: bot.seusite.com ou 192.168.1.100
PUBLIC_URL=http://localhost:3000

# =====================================================
# API Keys do Gemini (OBRIGATÓRIO)
# =====================================================
# Uma API Key por linha - o sistema usa rotação automática
# Obtenha suas chaves em: https://aistudio.google.com/app/apikey
API_KEYS_GEMINI=
SUA_API_KEY_AQUI_1
SUA_API_KEY_AQUI_2
SUA_API_KEY_AQUI_3

# =====================================================
# Mercado Pago (Opcional)
# =====================================================
# Token de acesso do Mercado Pago para receber pagamentos
MP_ACCESS_TOKEN=

# =====================================================
# Configurações Avançadas (geralmente não precisa mudar)
# =====================================================
PORT=3000
NODE_ENV=production